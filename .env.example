# ===========================================
# Vylux - Environment Variables
# ===========================================
# Copy this file to .env and fill in the values.
# See README.md for setup instructions and secret generation commands.

# --- Server ---
PORT=3000
MODE=all                          # all | server | worker

# --- Database ---
# Used by docker-compose.yml for the PostgreSQL container.
POSTGRES_USER=myuser
POSTGRES_PASSWORD=mypassword
POSTGRES_DB=mydb
# Connection string for Vylux (must match the credentials above).
# For docker-compose: use service name "postgres" as host.
# For local dev:      use "localhost".
DATABASE_URL=postgres://myuser:mypassword@postgres:5432/mydb

# --- Redis ---
# For docker-compose: use service name "redis" as host.
# For local dev:      use "localhost".
REDIS_URL=redis://redis:6379

# --- Source S3 / R2 ---
SOURCE_S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
SOURCE_S3_ACCESS_KEY=
SOURCE_S3_SECRET_KEY=
SOURCE_S3_REGION=auto
SOURCE_BUCKET=app-source-bucket   # Read-only originals

# --- Media S3 / R2 ---
# Even when source and media share the same backend, repeat the values explicitly.
MEDIA_S3_ENDPOINT=https://xxx.r2.cloudflarestorage.com
MEDIA_S3_ACCESS_KEY=
MEDIA_S3_SECRET_KEY=
MEDIA_S3_REGION=auto
MEDIA_BUCKET=media-bucket         # Read-write processed output

# --- Secrets (see README.md § Configuration for generation commands) ---
HMAC_SECRET=                      # Image URL signing (HMAC-SHA256)
API_KEY=                          # Bearer token for /api/* endpoints
WEBHOOK_SECRET=                   # Webhook callback signing (HMAC-SHA256)
KEY_TOKEN_SECRET=                 # AES key-delivery token (128-bit)
ENCRYPTION_KEY=                   # Wraps stored content keys in PostgreSQL (256-bit)

# --- Base URL ---
BASE_URL=                         # e.g. https://media.example.com (no trailing slash)

# --- Worker ---
WORKER_CONCURRENCY=10
LARGE_WORKER_CONCURRENCY=1      # Dedicated concurrency for the video:large queue
WORKER_METRICS_PORT=3001         # Worker-only metrics listener; set 0 to disable
LARGE_FILE_THRESHOLD=5368709120   # 5 GB
MAX_FILE_SIZE=53687091200         # 50 GB

# --- Cache ---
CACHE_MAX_SIZE=1073741824         # 1 GB in-memory LRU

# --- FFmpeg ---
FFMPEG_PATH=ffmpeg
SHAKA_PACKAGER_PATH=packager

# --- Timeouts ---
SHUTDOWN_TIMEOUT=30s
WORKER_SHUTDOWN_TIMEOUT=10m

# --- Logging ---
LOG_LEVEL=INFO                    # DEBUG | INFO | WARN | ERROR

# --- OpenTelemetry (optional) ---
OTEL_EXPORTER_OTLP_ENDPOINT=

# --- Cloudflare Tunnel (optional, used by docker-compose.yml) ---
# Create a tunnel at https://one.dash.cloudflare.com → Networks → Tunnels
# then paste the token here. Leave empty to disable the tunnel service.
TUNNEL_TOKEN=
